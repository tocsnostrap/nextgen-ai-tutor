# NextGen AI Tutor - Environment Configuration
# Copy this file to .env and update values for your environment

# Application
APP_NAME="NextGen AI Tutor"
APP_VERSION="1.0.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG="true"
LOG_LEVEL="INFO"

# Server
HOST="0.0.0.0"
PORT="8000"
WORKERS="4"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# Database - PostgreSQL with TimescaleDB
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_tutor"
DATABASE_POOL_SIZE="20"
DATABASE_MAX_OVERFLOW="40"

# Redis
REDIS_URL="redis://:redispassword@localhost:6379/0"
REDIS_POOL_SIZE="50"

# JWT Authentication
JWT_SECRET_KEY="your-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="30"
JWT_REFRESH_TOKEN_EXPIRE_DAYS="7"

# AI Model Serving
AI_MODEL_SERVER_URL="http://localhost:8001"
BKT_MODEL_PATH="/models/bkt/model.pkl"
EMOTION_MODEL_PATH="/models/emotion/model.pkl"
ADAPTATION_MODEL_PATH="/models/adaptation/model.pkl"

# Learning Analytics
ANALYTICS_BATCH_SIZE="1000"
ANALYTICS_FLUSH_INTERVAL="60"

# WebSocket
WEBSOCKET_MAX_CONNECTIONS="10000"
WEBSOCKET_PING_INTERVAL="30"
WEBSOCKET_PING_TIMEOUT="10"

# Monitoring
PROMETHEUS_ENABLED="true"
SENTRY_DSN=""  # Add your Sentry DSN for error tracking

# Rate Limiting
RATE_LIMIT_REQUESTS="100"
RATE_LIMIT_PERIOD="60"

# File Storage
UPLOAD_DIR="/uploads"
MAX_UPLOAD_SIZE="104857600"  # 100MB in bytes

# Email (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@ai-tutor.com"

# Cache
CACHE_TTL="300"

# External Services (optional)
OPENAI_API_KEY=""  # For advanced AI features
GOOGLE_CLOUD_API_KEY=""  # For speech-to-text, etc.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# Feature Flags
FEATURE_REALTIME_ANALYTICS="true"
FEATURE_EMOTION_DETECTION="true"
FEATURE_ADAPTIVE_LEARNING="true"
FEATURE_ASSESSMENTS="true"
FEATURE_NOTIFICATIONS="false"

# Security
ALLOWED_FILE_TYPES=".pdf,.txt,.doc,.docx,.jpg,.jpeg,.png,.mp3,.wav"
MAX_FILE_SIZE_MB="50"
ENABLE_RATE_LIMITING="true"
ENABLE_CORS="true"

# Development
RELOAD="true"  # Auto-reload on code changes
API_DOCS_ENABLED="true"  # Enable /docs and /redoc

# Testing
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_tutor_test"
TEST_REDIS_URL="redis://:redispassword@localhost:6379/1"

# Worker (Celery)
CELERY_BROKER_URL="redis://:redispassword@localhost:6379/2"
CELERY_RESULT_BACKEND="redis://:redispassword@localhost:6379/3"
CELERY_TASK_SERIALIZER="json"
CELERY_RESULT_SERIALIZER="json"
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE="UTC"

# Analytics Export
ANALYTICS_EXPORT_DIR="/exports"
ANALYTICS_RETENTION_DAYS="365"

# Backup
BACKUP_ENABLED="false"
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS="30"

# Load Balancer (for production)
LOAD_BALANCER_ENABLED="false"
LOAD_BALANCER_HOST="localhost"
LOAD_BALANCER_PORT="80"

# CDN (for production)
CDN_ENABLED="false"
CDN_URL="https://cdn.ai-tutor.com"
CDN_UPLOAD_PATH="/uploads"

# Monitoring URLs (for health checks)
PROMETHEUS_URL="http://localhost:9090"
GRAFANA_URL="http://localhost:3000"
REDIS_INSIGHT_URL="http://localhost:8001"

# Database Read Replica (for production scaling)
READ_REPLICA_ENABLED="false"
READ_REPLICA_URL="postgresql://readonly:password@replica-host:5432/ai_tutor"

# Cache Cluster (for production scaling)
REDIS_CLUSTER_ENABLED="false"
REDIS_CLUSTER_NODES="redis://:password@redis-node1:6379,redis://:password@redis-node2:6379,redis://:password@redis-node3:6379"

# Message Queue (for production scaling)
RABBITMQ_ENABLED="false"
RABBITMQ_URL="amqp://guest:guest@rabbitmq:5672/"

# Object Storage (for production)
S3_ENABLED="false"
S3_BUCKET="ai-tutor-storage"
S3_REGION="us-east-1"

# CDN for static assets
STATIC_CDN_ENABLED="false"
STATIC_CDN_URL="https://static.ai-tutor.com"

# API Versioning
API_VERSION="v1"
API_PREFIX="/api"

# WebSocket
WEBSOCKET_PATH="/ws"
WEBSOCKET_MAX_MESSAGE_SIZE="1048576"  # 1MB

# Session Management
SESSION_TIMEOUT="3600"  # 1 hour in seconds
SESSION_CLEANUP_INTERVAL="300"  # 5 minutes

# Password Policy
MIN_PASSWORD_LENGTH="8"
REQUIRE_SPECIAL_CHARS="true"
REQUIRE_NUMBERS="true"
REQUIRE_UPPERCASE="true"

# Email Verification
EMAIL_VERIFICATION_REQUIRED="true"
VERIFICATION_TOKEN_EXPIRE_HOURS="24"

# Account Lockout
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MINUTES="15"

# Audit Logging
AUDIT_LOG_ENABLED="true"
AUDIT_LOG_RETENTION_DAYS="90"

# Data Privacy
DATA_RETENTION_DAYS="365"
ANONYMIZE_OLD_DATA="true"
ANONYMIZE_AFTER_DAYS="180"

# Performance
QUERY_TIMEOUT="30"  # seconds
CONNECTION_TIMEOUT="10"  # seconds
REQUEST_TIMEOUT="60"  # seconds

# Compression
ENABLE_GZIP="true"
GZIP_MIN_SIZE="1000"  # bytes

# Security Headers
ENABLE_SECURITY_HEADERS="true"
CSP_ENABLED="true"
HSTS_ENABLED="true"

# Load Testing
LOAD_TEST_ENABLED="false"
LOAD_TEST_USERS="1000"
LOAD_TEST_DURATION="300"  # seconds

# A/B Testing
AB_TESTING_ENABLED="false"
AB_TESTING_COOKIE="ab_testing"

# Feature Rollout
FEATURE_ROLLOUT_PERCENTAGE="100"  # 0-100

# Maintenance Mode
MAINTENANCE_MODE="false"
MAINTENANCE_MESSAGE="System is under maintenance. Please try again later."

# Backup Encryption
BACKUP_ENCRYPTION_ENABLED="false"
BACKUP_ENCRYPTION_KEY=""

# Disaster Recovery
DR_ENABLED="false"
DR_REPLICATION_LAG_THRESHOLD="60"  # seconds

# Cost Optimization
ENABLE_COST_OPTIMIZATION="false"
COST_ALERT_THRESHOLD="1000"  # dollars

# Compliance
GDPR_COMPLIANT="true"
HIPAA_COMPLIANT="false"
COPPA_COMPLIANT="true"  # Children's Online Privacy Protection Act